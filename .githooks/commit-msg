#!/usr/bin/env sh

msg_file="$1"
first_line="$(head -n 1 "$msg_file")"
pattern='^(feat|fix|refactor|perf|docs|test|build|ci|chore|revert)\([a-z0-9._-]+\): .{1,72}$'
obsidian_pattern='^vault backup: .*$'

if echo "$first_line" | grep -Eq "$obsidian_pattern"; then
  exit 0
fi

echo "$first_line" | grep -Eq "$pattern"
if [ $? -ne 0 ]; then
  echo "Invalid commit message format."
  echo "Expected: type(scope): subject"
  echo "Example: feat(schema): add patch conflict detection"
  exit 1
fi

exit 0
