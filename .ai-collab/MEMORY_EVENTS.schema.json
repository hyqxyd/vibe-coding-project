{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Collab Memory Event",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "timestamp",
    "branch",
    "actor",
    "summary",
    "files",
    "risk"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 8
    },
    "event_type": {
      "type": "string",
      "enum": [
        "async_update",
        "sync_merge",
        "review_reject",
        "review_pass",
        "risk_alert"
      ]
    },
    "timestamp": {
      "type": "string"
    },
    "branch": {
      "type": "string",
      "minLength": 1
    },
    "actor": {
      "type": "object",
      "required": [
        "type",
        "id"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "human",
            "ai"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risk": {
      "type": "object",
      "required": [
        "level"
      ],
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "validation": {
      "type": "object",
      "properties": {
        "human_review": {
          "type": "string",
          "enum": [
            "pending",
            "approved",
            "rejected"
          ]
        },
        "test_status": {
          "type": "string",
          "enum": [
            "unknown",
            "passed",
            "failed"
          ]
        }
      }
    },
    "metadata": {
      "type": "object"
    }
  }
}
